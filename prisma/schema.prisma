// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id  String @id @default(uuid())
  name  String  
  email String @unique
  password String
  role Role @default(USER)

  ownedWorkspaces Workspace[] @relation("OwnedWorkspaces")
  workspaceMemberships Workspace[] @relation("WorkspaceMembers")

  tasksAssigned Task[] @relation("TaskAssignees")
  tasksCreated Task[] @relation("TaskCreator")

  projectsCreated Project[] @relation("ProjectCreator")
  projectsAssigned Project[] @relation("ProjectAssignees")

  activityLogs ActivityLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role{
  USER
  ADMIN
}

model Workspace{
  id  String @id @default(uuid())
  name  String 
  description String

  ownerId String
  owner User @relation("OwnedWorkspaces",fields: [ownerId], references: [id], onDelete: Cascade)

  members User[] @relation("WorkspaceMembers")
  projects Project[]

  activityLogs ActivityLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([ownerId])
}

model Project{
  id  String @id @default(uuid())
  name String
  description String

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdById String
  createdBy User @relation("ProjectCreator",fields: [createdById], references: [id])

  assignees User[] @relation("ProjectAssignees")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([workspaceId])
  @@index([createdById])
}

model Task{
  id  String @id @default(uuid())
  name String
  description String
  status TaskStatus

  projectId String
  project Project @relation(fields: [projectId], references: [id])

  createdById String
  createdBy User @relation("TaskCreator",fields: [createdById], references: [id])

  assignees User[] @relation("TaskAssignees")

  dueDate DateTime?
  priority TaskPriority @default(MEDIUM)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
  @@index([createdById])
}

enum TaskStatus{
  PENDING
  IN_PROGRESS
  COMPLETED
  IN_REVIEW
  FINISHED
  CLOSED
}

model ActivityLog{
  id  String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id],onDelete: Cascade)

  action ActionType
  entityType EntityType
  entityId String

  timestamp DateTime @default(now())

  workspaceId String
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([workspaceId])
  @@index([entityId])
}

enum ActionType{
  CREATE
  UPDATE
  DELETE
}

enum EntityType{
  TASK
  PROJECT
  WORKSPACE
  USER
}

enum TaskPriority{
  LOW
  MEDIUM
  HIGH
  URGENT
}